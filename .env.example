# Copy to .env and fill in. .env is gitignored. Used by scripts/ and rendered into the VM.
# These same values also feed Terraform as TF_VAR_* (scripts/lib/common.sh exports them).

# ── Dynatrace (telemetry destination) ────────────────────────────────────────
# REQUIRED: full Dynatrace OTLP ingest base URL, ending in /api/v2/otlp. This drives the BindPlane
# dynatrace_otlp destination's custom_url (deployment_type=Custom), which works for ANY tenant type:
#   • Gen 3 / sprint / labs:  https://<envid>.sprint.dynatracelabs.com/api/v2/otlp
#   • Standard SaaS:          https://<envid>.live.dynatrace.com/api/v2/otlp
#   • Managed/ActiveGate:     https://<activegate-host>:9999/e/<envid>/api/v2/otlp
DT_OTLP_ENDPOINT=

# Dynatrace token (Gen 3 platform token dt0s16.* OR classic access token dt0c01.*). MUST have all
# three ingest permissions. Gen 3 / OpenPipeline scope names:
#   openpipeline:metrics:ingest · openpipeline:logs:ingest · openpipeline:events:ingest (traces)
# Classic (Gen 2) names: metrics.ingest · logs.ingest · openTelemetryTrace.ingest. Verify with:
#   curl -s -o /dev/null -w '%{http_code}' -X POST "$DT_OTLP_ENDPOINT/v1/metrics" \
#     -H "Authorization: Api-Token $DT_API_TOKEN" -H "Content-Type: application/x-protobuf" --data-binary ''
#   200 = permission OK · 403 = missing that signal's ingest scope · 401 = bad token.
DT_API_TOKEN=

# Optional (reference only — not used by the destination, which uses DT_OTLP_ENDPOINT above):
# DT_ENV_ID=

# ── BindPlane Cloud (OpAMP enrollment + CLI apply) ────────────────────────────
# From BindPlane UI: Agents > Install Agent. Copy the endpoint and secret from the install command.
BP_OPAMP_ENDPOINT=wss://app.bindplane.com/v1/opamp
BP_SECRET_KEY=

# BindPlane API key (free plan HAS API access). UI: Settings > API Keys.
# Used by the `bindplane` CLI (--api-key flag). Enables automated pipeline apply from up.sh
# (`bindplane apply -f destinations.yaml` then `bindplane apply -f configurations.yaml`).
# Without this, up.sh warns and skips pipeline apply — collectors enroll but have no config.
BP_API_KEY=

# BindPlane Cloud URL (optional — defaults to https://app.bindplane.com).
# Override only if using a self-hosted BindPlane instance.
# BP_REMOTE_URL=https://app.bindplane.com

# LOCAL PREREQUISITE: the `bindplane` CLI must be installed on the operator's machine.
# Pipeline apply runs from your machine targeting BindPlane Cloud — NOT from the demo VM.
# Install: brew tap observiq/bindplane && brew install bindplane   (macOS)
#          https://docs.bindplane.observiq.com/docs/install-cli    (all platforms)

# ── Azure / infra ────────────────────────────────────────────────────────────
AZURE_LOCATION=eastus
VM_SIZE=Standard_B2s
# Path to an SSH public key used for VM admin access (key auth only).
SSH_PUBLIC_KEY_PATH=~/.ssh/id_rsa.pub
# Restrict inbound SSH to this CIDR (your IP/32). Leave blank to auto-detect current public IP.
ADMIN_SOURCE_CIDR=
