# Copy to terraform.tfvars (gitignored) and fill in.
# Secrets live in secrets.auto.tfvars (also gitignored) — do NOT put them here.
# scripts/up.sh generates both files from .env automatically.

demo            = "manufacturing"
region          = "us-east-1"
instance_type   = "t3.medium"
admin_username  = "ubuntu"
resource_prefix = "bpdemo"

# Narrow to your workstation IP to avoid exposing SSH publicly:
# admin_source_cidr = "203.0.113.10/32"
admin_source_cidr = "0.0.0.0/0"

# ssh_public_key is typically sourced from ~/.ssh/id_rsa.pub or id_ed25519.pub.
# scripts/up.sh reads SSH_PUBLIC_KEY_PATH from .env and injects it.
# ssh_public_key = "ssh-ed25519 AAAA..."
