# collectors/gateway.env
# Per-collector OPAMP_LABELS for the gateway collector.
# MUST match selector in bindplane/configurations.yaml (energy-gateway).
# 'configuration=<name>' is what BindPlane uses to bind an agent to a Configuration.
# Without it, matchLabels selectors only feed the rollout phase set; agents never bind.
OPAMP_LABELS=configuration=energy-gateway,role=gateway,demo=energy,region=region-east-1
