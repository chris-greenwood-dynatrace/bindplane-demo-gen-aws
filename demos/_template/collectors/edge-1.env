# collectors/edge-1.env
# Per-collector OPAMP_LABELS for the edge-1 collector.
# These MUST match the selector in bindplane/configurations.yaml for the edge configuration.
# 'configuration=<name>' is what BindPlane uses to bind an agent to a Configuration.
# Without it, matchLabels selectors only feed the rollout phase set; agents never bind.
OPAMP_LABELS=configuration=<DEMO_NAME>-edge,role=edge,demo=<DEMO_NAME>,zone=<zone-id>
