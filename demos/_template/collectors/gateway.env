# collectors/gateway.env
# Per-collector OPAMP_LABELS for the gateway collector.
# These MUST match the selector in bindplane/configurations.yaml for the gateway configuration.
# Format: key=value,key2=value2 (BindPlane label selector syntax)
# 'configuration=<name>' is what BindPlane uses to bind an agent to a Configuration.
# Without it, matchLabels selectors only feed the rollout phase set; agents never bind.
OPAMP_LABELS=configuration=<DEMO_NAME>-gateway,role=gateway,demo=<DEMO_NAME>,site=<site-id>
